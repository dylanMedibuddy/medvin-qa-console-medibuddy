# Supabase
# server-only, never expose to client
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Make integration — shared secret for legacy /api/make/* endpoints.
# Detection + rewrite now run in-app (see CRON_SECRET below); these endpoints
# are kept around for backward compat but no longer drive the pipeline.
MAKE_API_KEY=

# Cron auth — shared secret for the /api/cron/* endpoints (detect + rewrite
# jobs invoked on a schedule by Railway cron). Generate: openssl rand -hex 32
CRON_SECRET=

# OpenAI API key — used by the in-app detector and rewriter (gpt-5.2).
OPENAI_API_KEY=

# Medvin admin — read-only fetches (bank list + question pages for detection).
# All Medvin writes still go through Make Scenario B for now.
MEDVIN_BASE_URL=https://hub.medibuddy.co.uk
MEDVIN_ADMIN_EMAIL=
MEDVIN_ADMIN_PASSWORD=

# Auth
ADMIN_BOOTSTRAP_EMAIL=dylan@medibuddy.co.uk

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
