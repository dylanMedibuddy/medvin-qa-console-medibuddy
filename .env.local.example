# Supabase
# server-only, never expose to client
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Make integration — shared secret for /api/make/* endpoints
# Generate with: openssl rand -hex 32
MAKE_API_KEY=

# Webhook URL for Make Scenario A (detection + LLM rewrite).
# The "Run now" UI button POSTs { question_bank_id, question_bank_title, triggered_by } here.
MAKE_SCENARIO_A_WEBHOOK_URL=

# Medvin admin (READ-ONLY usage in this app — only used to populate the
# bank dropdown via GET /api/admin/question-banks). All Medvin writes
# happen via Make Scenario B, which holds its own credentials.
MEDVIN_BASE_URL=https://hub.medibuddy.co.uk
MEDVIN_ADMIN_EMAIL=
MEDVIN_ADMIN_PASSWORD=

# Auth
ADMIN_BOOTSTRAP_EMAIL=dylan@medibuddy.co.uk

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
